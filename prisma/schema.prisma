generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ColoringPage {
    id           String            @id @default(cuid())
    title        String
    slug         String            @unique
    description  String?
    prompt       String?
    imageUrl     String?
    imageKey     String?
    pdfUrl       String            @default("")
    pdfKey       String            @default("")
    thumbnailUrl String?
    approved         Boolean?
    promptComponents Json?             // {animal, action, scene, props} stored for diversity tracking
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    revisions        ReviewRevision[]

    @@index([createdAt])
    @@index([approved])
}

model ReviewRevision {
    id             String       @id @default(cuid())
    coloringPageId String
    coloringPage   ColoringPage @relation(fields: [coloringPageId], references: [id], onDelete: Cascade)
    reviewComment  String
    attempt        Int
    imageUrl       String
    imageKey       String
    chosen         Boolean      @default(false)
    createdAt      DateTime     @default(now())

    @@index([coloringPageId])
}

model PromptIdea {
    id        String   @id @default(cuid())
    animal    String
    action    String
    scene     String
    props     String
    used      Boolean  @default(false)
    createdAt DateTime @default(now())

    @@index([used])
}

model ImageGuideline {
    id          String   @id @default(cuid())
    guideline   String   // The synthesized guideline text
    occurrences Int      @default(1) // How many times similar feedback has been given
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([updatedAt])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
